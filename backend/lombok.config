# Lombok configuration for the boat-management backend.
#
# Prevents lombok.config inheritance from parent directories.
config.stopBubbling = true

# Instruct Lombok to copy null-annotations through to generated code
# (constructors, builders, setters, etc.) using Spring's annotation set.
# This tells JDT that:
#   - @Builder.build() returns @NonNull T
#   - @NonNull-annotated fields produce @NonNull builder methods
#   - @Nullable-annotated fields produce @Nullable builder methods
#
# Spring's org.springframework.lang.NonNull / Nullable are on the classpath
# via spring-core, so no extra dependency is needed.
lombok.addNullAnnotations = spring
