# ──────────────────────────────────────────
# Boat Management Application - Environment
# ──────────────────────────────────────────
# Copy this file to .env and customize values

# Database
DB_NAME=boatdb
DB_USER=boatuser
DB_PASSWORD=boatpassword_change_in_prod

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_in_prod
KEYCLOAK_REALM=boat-realm

# Keycloak test users (injected into realm-export at startup)
KC_BOATUSER_PASSWORD=change_me
KC_BOATADMIN_PASSWORD=change_me

# Backend
SERVER_PORT=8081
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80
